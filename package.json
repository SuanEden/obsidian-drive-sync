{
  "name": "obsidian-drive-sync",
  "version": "0.10.5",
  "description": "Plugin pessoal de sincronização bidirecional entre Obsidian e Google Drive.",
  "type": "module",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc --noEmit && node esbuild.config.mjs production",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run"
  },
  "keywords": [
    "obsidian",
    "google-drive",
    "sync"
  ],
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@types/node": "^24.1.0",
    "builtin-modules": "^5.0.0",
    "esbuild": "^0.25.8",
    "eslint": "^9.32.0",
    "eslint-plugin-obsidianmd": "^0.1.9",
    "globals": "^16.3.0",
    "obsidian": "^1.8.7",
    "prettier": "^3.6.2",
    "tslib": "^2.8.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.38.0",
    "vitest": "^3.2.4"
  }
}
